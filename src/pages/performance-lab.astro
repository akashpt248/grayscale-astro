---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Performance Lab"
  description="Controlled performance stress tests for the site"
>
  <main class="performance-lab" data-performance-lab data-hero-image={`${base}assets/img/bg-masthead.jpg`}>
    <section class="lab-hero">
      <div class="container px-4 px-lg-5 py-5">
        <div class="row align-items-center g-5 py-4">
          <div class="col-lg-7">
            <p class="lab-kicker">Controlled stress testing</p>
            <h1 class="display-5 text-white mb-3">Performance Lab</h1>
            <p class="lead text-white-50 mb-4">
              Use these presets to progressively introduce motion, large datasets, concurrent requests, media,
              DOM growth, third-party widgets, and interactive state changes.
            </p>
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-primary" type="button" data-preset="baseline">Baseline</button>
              <button class="btn btn-outline-light" type="button" data-preset="motion">Motion</button>
              <button class="btn btn-outline-light" type="button" data-preset="data">Data pressure</button>
              <button class="btn btn-outline-light" type="button" data-preset="max">Full load</button>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="lab-summary card border-0">
              <div class="card-body p-4 p-lg-5">
                <p class="text-uppercase text-primary small mb-2">What is included</p>
                <ul class="lab-summary-list">
                  <li>CSS, SVG, and JS animation pressure</li>
                  <li>Large dataset fetches and repeated concurrent requests</li>
                  <li>Repeated large image rendering</li>
                  <li>Large DOM and infinite content collection tests</li>
                  <li>Simulated third-party script load</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5 bg-black text-white">
      <div class="container px-4 px-lg-5">
        <div class="row g-4">
          <div class="col-lg-8">
            <div class="card lab-panel border-0">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">Stress knobs</p>
                    <h2 class="h3 mb-0">Tune the pressure manually</h2>
                  </div>
                  <button class="btn btn-sm btn-outline-light" type="button" id="loadDataset">
                    Reload data
                  </button>
                </div>

                <div class="row g-3">
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="datasetSize">Dataset size</label>
                    <select class="form-select" id="datasetSize">
                      <option value="small">Small</option>
                      <option value="medium">Medium</option>
                      <option value="large">Large</option>
                    </select>
                  </div>
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="concurrentRequests">Concurrent requests</label>
                    <input class="form-range" id="concurrentRequests" type="range" min="1" max="8" step="1" />
                  </div>
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="imageCount">Large images</label>
                    <input class="form-range" id="imageCount" type="range" min="0" max="12" step="1" />
                  </div>
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="domCount">DOM nodes</label>
                    <input class="form-range" id="domCount" type="range" min="24" max="600" step="24" />
                  </div>
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="batchSize">Infinite batch size</label>
                    <input class="form-range" id="batchSize" type="range" min="12" max="96" step="12" />
                  </div>
                  <div class="col-md-6 col-xl-4">
                    <label class="form-label" for="sortMode">Sort order</label>
                    <select class="form-select" id="sortMode">
                      <option value="score">Score</option>
                      <option value="title">Title</option>
                    </select>
                  </div>
                </div>

                <div class="row g-3 mt-3">
                  <div class="col-md-6 col-xl-3">
                    <label class="form-check stress-toggle">
                      <input class="form-check-input" type="checkbox" id="motionToggle" />
                      <span class="form-check-label">Complex animation</span>
                    </label>
                  </div>
                  <div class="col-md-6 col-xl-3">
                    <label class="form-check stress-toggle">
                      <input class="form-check-input" type="checkbox" id="dataToggle" />
                      <span class="form-check-label">Large data</span>
                    </label>
                  </div>
                  <div class="col-md-6 col-xl-3">
                    <label class="form-check stress-toggle">
                      <input class="form-check-input" type="checkbox" id="thirdPartyToggle" />
                      <span class="form-check-label">Third-party script</span>
                    </label>
                  </div>
                  <div class="col-md-6 col-xl-3">
                    <label class="form-check stress-toggle">
                      <input class="form-check-input" type="checkbox" id="interactiveToggle" />
                      <span class="form-check-label">Interactive state</span>
                    </label>
                  </div>
                  <div class="col-md-6 col-xl-3">
                    <label class="form-check stress-toggle">
                      <input class="form-check-input" type="checkbox" id="infiniteToggle" />
                      <span class="form-check-label">Infinite scroll</span>
                    </label>
                  </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                  <span class="lab-chip">Hydration-like state updates</span>
                  <span class="lab-chip">Media decode pressure</span>
                  <span class="lab-chip">Request fanout</span>
                  <span class="lab-chip">DOM expansion</span>
                </div>

                <div class="lab-metrics mt-4">
                  <div class="lab-metric"><span>Frame loop</span><strong data-metric="frames">0 frames</strong></div>
                  <div class="lab-metric"><span>Items rendered</span><strong data-metric="items">0 items</strong></div>
                  <div class="lab-metric"><span>Requests</span><strong data-metric="requests">0 requests</strong></div>
                  <div class="lab-metric"><span>Media</span><strong data-metric="images">0 images</strong></div>
                  <div class="lab-metric"><span>DOM</span><strong data-metric="dom">0 cards</strong></div>
                  <div class="lab-metric"><span>Widget</span><strong data-metric="widget">idle</strong></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="card lab-panel border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <p class="text-uppercase text-primary small mb-2">Status</p>
                <h2 class="h4 mb-4">How the current preset is behaving</h2>
                <p class="text-white-50 mb-4" id="dataSummary">Waiting for data...</p>
                <p class="text-white-50 mb-4" id="requestSummary">No concurrent requests yet.</p>
                <div id="thirdPartyStatus" class="lab-status">idle</div>
                <p class="text-white-50 mt-4 mb-0">
                  The lab begins light, then lets you ramp up each pressure source independently so you can compare
                  Lighthouse behavior before and after the added load.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5">
      <div class="container px-4 px-lg-5">
        <div class="row g-4">
          <div class="col-lg-6">
            <div class="lab-stage card border-0 h-100" id="motionStage">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">Motion</p>
                    <h2 class="h4 mb-0">CSS + SVG animation pressure</h2>
                  </div>
                  <span class="lab-chip">rAF + transforms</span>
                </div>

                <div class="lab-motion-shell" data-motion-dial>
                  <div class="lab-motion-orb"></div>
                  <div class="lab-motion-orb lab-motion-orb--alt"></div>
                  <svg class="lab-motion-svg" viewBox="0 0 220 220" aria-hidden="true">
                    <circle cx="110" cy="110" r="82"></circle>
                    <circle cx="110" cy="110" r="52"></circle>
                  </svg>
                </div>
                <p class="text-black-50 mb-0">
                  This stage combines layered CSS animation, SVG strokes, and a JavaScript frame loop to mimic the
                  kind of motion that can compete with rendering work on a real page.
                </p>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="lab-stage card border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">Data</p>
                    <h2 class="h4 mb-0">Fetched dataset and interactive filtering</h2>
                  </div>
                  <button class="btn btn-sm btn-outline-dark" type="button" id="refreshRequests">Refetch fanout</button>
                </div>
                <div class="lab-filter mb-4">
                  <input
                    id="query"
                    type="search"
                    class="form-control"
                    placeholder="Filter by title, category, or summary"
                  />
                </div>
                <ul class="lab-feed-list" id="datasetList"></ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5 bg-black text-white">
      <div class="container px-4 px-lg-5">
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="lab-stage lab-stage--dark card border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <p class="text-uppercase text-primary small mb-1">DOM growth</p>
                <h2 class="h4 mb-3">Large nested component trees</h2>
                <p class="text-white-50 mb-4">
                  This panel expands into hundreds of repeated cards to mimic long feeds, dense dashboards, and
                  other pages where the DOM itself becomes a bottleneck.
                </p>
                <div class="lab-chip mb-2">component complexity</div>
                <div class="lab-chip">layout and paint pressure</div>
              </div>
            </div>
          </div>
          <div class="col-lg-8">
            <div class="lab-stage lab-stage--dark card border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">State management</p>
                    <h2 class="h4 mb-0">Interactive rerenders at scale</h2>
                  </div>
                  <span class="lab-chip">search + sort</span>
                </div>
                <div class="lab-data-grid" id="domGrid"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5 bg-black text-white">
      <div class="container px-4 px-lg-5">
        <div class="row g-4">
          <div class="col-lg-7">
            <div class="lab-stage lab-stage--dark card border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">Media</p>
                    <h2 class="h4 mb-0">Large image assets</h2>
                  </div>
                  <span class="lab-chip">decode pressure</span>
                </div>
                <div class="lab-image-grid" id="imageGrid"></div>
              </div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="lab-stage lab-stage--dark card border-0 h-100">
              <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                  <div>
                    <p class="text-uppercase text-primary small mb-1">Third-party</p>
                    <h2 class="h4 mb-0">Simulated widget payload</h2>
                  </div>
                  <span class="lab-chip">async script</span>
                </div>
                <div class="lab-widget-host" id="widgetHost"></div>
                <p class="text-white-50 mt-4 mb-0">
                  This local widget behaves like an analytics or ad snippet by injecting work after the page starts
                  loading. It is safe to remove, but useful for comparing how a third-party script shifts the metrics.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5">
      <div class="container px-4 px-lg-5">
        <div class="lab-stage card border-0">
          <div class="card-body p-4 p-lg-5">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
              <div>
                <p class="text-uppercase text-primary small mb-1">Infinite content</p>
                <h2 class="h4 mb-0">Lazy loading and pagination pressure</h2>
              </div>
              <span class="lab-chip">intersection observer</span>
            </div>
            <div class="lab-feed" id="feedList"></div>
            <div id="feedSentinel" class="lab-feed-sentinel" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="/js/performance-lab.js" defer></script>

  <style is:global>
    .performance-lab {
      background:
        radial-gradient(circle at top left, rgba(100, 161, 157, 0.24), transparent 28%),
        radial-gradient(circle at top right, rgba(116, 100, 161, 0.22), transparent 24%),
        #0b0f14;
      color: #0f172a;
    }

    .lab-hero {
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(135deg, rgba(6, 13, 22, 0.9), rgba(10, 18, 29, 0.75)),
        url('/assets/img/bg-masthead.jpg') center/cover no-repeat;
    }

    .lab-hero::before,
    .lab-hero::after {
      content: '';
      position: absolute;
      border-radius: 999px;
      filter: blur(40px);
      opacity: 0.3;
      pointer-events: none;
    }

    .lab-hero::before {
      width: 24rem;
      height: 24rem;
      top: -8rem;
      right: -5rem;
      background: rgba(100, 161, 157, 0.45);
    }

    .lab-hero::after {
      width: 18rem;
      height: 18rem;
      left: -4rem;
      bottom: -7rem;
      background: rgba(116, 100, 161, 0.4);
    }

    .lab-hero > .container,
    .lab-panel,
    .lab-stage,
    .lab-summary {
      position: relative;
      z-index: 1;
    }

    .lab-kicker {
      color: #8ad7d2;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-size: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .lab-summary {
      backdrop-filter: blur(16px);
      background: rgba(255, 255, 255, 0.9);
      border-radius: 1.5rem;
      box-shadow: 0 1.25rem 4rem rgba(8, 15, 24, 0.24);
    }

    .lab-summary-list {
      margin: 0;
      padding-left: 1.25rem;
      color: #334155;
    }

    .lab-summary-list li + li {
      margin-top: 0.6rem;
    }

    .lab-panel,
    .lab-stage {
      border-radius: 1.5rem;
      box-shadow: 0 1rem 3rem rgba(8, 15, 24, 0.12);
    }

    .lab-stage {
      background: #fff;
      color: #0f172a;
    }

    .lab-panel {
      background: rgba(12, 18, 28, 0.94);
      color: #e5eef5;
    }

    .lab-stage--dark {
      background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
      color: #f8fafc;
    }

    .lab-chip,
    .lab-status {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2rem;
      padding: 0.35rem 0.8rem;
      border-radius: 999px;
      font-size: 0.82rem;
      letter-spacing: 0.02em;
    }

    .lab-chip {
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(255, 255, 255, 0.06);
      color: #e2e8f0;
    }

    .lab-status {
      border: 1px solid rgba(100, 161, 157, 0.24);
      background: rgba(100, 161, 157, 0.1);
      color: #7fe0d8;
      text-transform: uppercase;
      letter-spacing: 0.14em;
    }

    .stress-toggle {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.7rem 0.9rem;
      border-radius: 0.9rem;
      background: rgba(255, 255, 255, 0.04);
    }

    .stress-toggle .form-check-input {
      margin-top: 0;
    }

    .lab-metrics {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .lab-metric {
      padding: 1rem;
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.04);
    }

    .lab-metric span {
      display: block;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(226, 232, 240, 0.7);
      margin-bottom: 0.45rem;
    }

    .lab-metric strong {
      display: block;
      font-size: 1.05rem;
      color: #fff;
    }

    .lab-motion-shell {
      position: relative;
      aspect-ratio: 1;
      border-radius: 1.5rem;
      margin-bottom: 1.25rem;
      overflow: hidden;
      background:
        radial-gradient(circle at 30% 30%, rgba(100, 161, 157, 0.18), transparent 35%),
        radial-gradient(circle at 70% 70%, rgba(116, 100, 161, 0.16), transparent 40%),
        #f8fafc;
    }

    .lab-motion-orb {
      position: absolute;
      inset: 18% auto auto 12%;
      width: 40%;
      aspect-ratio: 1;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(100, 161, 157, 0.9), rgba(28, 171, 196, 0.55));
      filter: blur(0.25rem);
      opacity: 0.9;
    }

    .lab-motion-orb--alt {
      inset: auto 12% 14% auto;
      width: 32%;
      background: linear-gradient(135deg, rgba(116, 100, 161, 0.9), rgba(214, 51, 132, 0.45));
    }

    .lab-motion-svg {
      position: absolute;
      inset: 50% auto auto 50%;
      width: 72%;
      transform: translate(-50%, -50%) rotate(-14deg);
      stroke: rgba(15, 23, 42, 0.3);
      fill: none;
      stroke-width: 10;
      stroke-linecap: round;
    }

    .lab-motion-svg circle:last-child {
      stroke-dasharray: 15 18;
    }

    .motion-enabled .lab-motion-shell .lab-motion-orb,
    .motion-enabled .lab-motion-shell .lab-motion-orb--alt {
      animation: orbit 8s linear infinite;
    }

    .motion-enabled .lab-motion-shell .lab-motion-orb--alt {
      animation-duration: 11s;
      animation-direction: reverse;
    }

    .motion-enabled .lab-motion-svg circle {
      animation: dash 5s linear infinite;
    }

    .motion-enabled .lab-motion-svg circle:last-child {
      animation-duration: 3.5s;
    }

    @keyframes orbit {
      from {
        transform: translate3d(0, 0, 0) scale(1);
      }
      50% {
        transform: translate3d(18px, -10px, 0) scale(1.08);
      }
      to {
        transform: translate3d(0, 0, 0) scale(1);
      }
    }

    @keyframes dash {
      from {
        stroke-dashoffset: 0;
      }
      to {
        stroke-dashoffset: -320;
      }
    }

    .lab-filter .form-control {
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1rem;
      min-height: 3rem;
    }

    .lab-feed-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.85rem;
      max-height: 42rem;
      overflow: auto;
    }

    .lab-feed-list .lab-feed-item {
      background: rgba(15, 23, 42, 0.04);
      border-color: rgba(15, 23, 42, 0.08);
    }

    .lab-feed-item,
    .lab-feed-card,
    .lab-data-card {
      border-radius: 1rem;
      padding: 1rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .lab-feed-item strong,
    .lab-feed-card strong,
    .lab-data-card h3 {
      display: block;
      margin-bottom: 0.45rem;
      color: inherit;
    }

    .lab-feed-item span,
    .lab-data-card__header {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(148, 163, 184, 0.92);
      margin-bottom: 0.65rem;
    }

    .lab-feed-item strong,
    .lab-feed-item p {
      color: #0f172a;
    }

    .lab-feed-item span {
      color: #475569;
    }

    .lab-data-card__header strong {
      margin: 0;
      letter-spacing: 0.16em;
    }

    .lab-data-card__meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin: 1rem 0 0;
    }

    .lab-data-card__meta div {
      padding: 0.8rem;
      border-radius: 0.8rem;
      background: rgba(255, 255, 255, 0.04);
    }

    .lab-data-card__meta dt {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(148, 163, 184, 0.8);
    }

    .lab-data-card__meta dd {
      margin: 0.35rem 0 0;
      font-weight: 700;
    }

    .lab-feed-item p,
    .lab-feed-card p,
    .lab-data-card p {
      margin-bottom: 0;
      color: rgba(226, 232, 240, 0.8);
    }

    .lab-data-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
    }

    .lab-image-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .lab-image-card {
      margin: 0;
      overflow: hidden;
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .lab-image-card img {
      display: block;
      width: 100%;
      height: 12rem;
      object-fit: cover;
      object-position: center;
    }

    .lab-image-card figcaption {
      padding: 0.8rem 0.9rem;
      color: rgba(226, 232, 240, 0.78);
      font-size: 0.9rem;
    }

    .lab-widget-host {
      min-height: 12rem;
    }

    .third-party-widget {
      position: fixed;
      right: 1rem;
      bottom: 1rem;
      z-index: 1050;
      width: min(20rem, calc(100vw - 2rem));
      padding: 1rem;
      border-radius: 1rem;
      color: #0f172a;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 1rem 3rem rgba(8, 15, 24, 0.24);
      transform: rotate(var(--widget-tilt, 0deg));
      transform-origin: bottom right;
    }

    .third-party-widget.is-hot {
      outline: 2px solid rgba(100, 161, 157, 0.6);
    }

    .third-party-widget__title,
    .third-party-widget__stats {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .third-party-widget__title {
      margin-bottom: 0.75rem;
    }

    .third-party-widget__title span {
      color: #64748b;
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
    }

