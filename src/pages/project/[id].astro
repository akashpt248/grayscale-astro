---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchChildProjects } from '../../data/projects';

export async function getStaticPaths() {
  const childProjects = await fetchChildProjects();

  return childProjects.map((child) => ({
    params: { id: String(child.id) },
    props: { child },
  }));
}

const { child } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={child.title} description={child.content}>
  <section class="about-section text-center" id="project-detail">
    <div class="container px-4 px-lg-5">
      <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-lg-8">
          <img
            class="img-fluid mb-4"
            src={child.imageurl}
            alt={child.title}
          />

          <h1 class="text-white mb-4">{child.title}</h1>

          <p class="text-white-50 mb-5">{child.content}</p>

           
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
